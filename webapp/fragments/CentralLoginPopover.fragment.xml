<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Popover
        id="centralLoginPopover"
        title="EWM Central Login"
        placement="PreferredLeftOrFlip"
        contentWidth="22rem">

        <content>

            <VBox
                id="loginVBox"
                class="sapUiSmallMargin">

                <Label
                    id="warehouseLabel"
                    text="Warehouse" />

                <ComboBox
                    id="warehouseSelect"
                    selectedKey="{popover_state>/warehouseNo}"
                    selectionChange="onWarehouseChanged"
                    
                    items="{
                        path: 'backend>/Warehouses'
                    }">
                    <core:Item
                        id="warehouseItem"
                        key="{backend>WarehouseNo}"
                        text="{backend>Description}" />
                </ComboBox>

                <Label
                    id="workCenterLabel"
                    text="Work Center" />

                <ComboBox
                    id="workCenterSelect"
                    selectedKey="{popover_state>/workCenterId}"
                    items="{backend>/Workcenters}">
                    <core:Item
                        id="workCenterItem"
                        key="{backend>Workstation}"
                        text="{backend>Description}" />
                </ComboBox>

                <Label
                    id="resourceLabel"
                    text="Resource" />

                <ComboBox
                    id="resourceSelect"
                    selectedKey="{popover_state>/resourceId}"
                    items="{backend>/Resources}">
                    <core:Item
                        id="resourceItem"
                        key="{backend>Rsrc}"
                        text="{backend>Rsrc}" />
                </ComboBox>

            </VBox>

        </content>

        <footer>

            <Toolbar
                id="footerToolbar">

                <ToolbarSpacer id="footerToolbarSpacer" />

                <!-- Save: stores current selection as permanent preferences, does not log in -->
                <Button
                    id="saveButton"
                    text="Save"
                    icon="sap-icon://save"
                    press="onSavePress" />

                <!-- Login: only visible when not logged in -->
                <Button
                    id="loginButton"
                    text="Login"
                    type="Emphasized"
                    visible="{= ${state>/isLoggedIn} === false }"
                    press="onLoginPress" />

                <!-- Logout: only visible when logged in -->
                <Button
                    id="logoutButton"
                    text="Logout"
                    icon="sap-icon://log"
                    visible="{state>/isLoggedIn}"
                    press="onLogoutPress" />

                <!-- Cancel: always visible -->
                <Button
                    id="cancelButton"
                    text="Cancel"
                    press="onCancelPress" />

            </Toolbar>

        </footer>

    </Popover>

</core:FragmentDefinition>