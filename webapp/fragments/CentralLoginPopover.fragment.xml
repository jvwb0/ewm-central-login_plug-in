<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Popover
        id="centralLoginPopover"
        title="EWM Central Login"
        placement="PreferredLeftOrFlip"
        contentWidth="22rem">

        <content>

            <VBox
                id="loginVBox"
                class="sapUiSmallMargin">

                <Label
                    id="warehouseLabel"
                    text="Warehouse" />

                <ComboBox
                    id="warehouseSelect"
                    selectedKey="{loginDraft>/warehouseNo}"
                    selectionChange="onWarehouseChanged"
                    items="{backend>/Warehouses}">
                    <core:Item
                        key="{backend>warehouseNo}"
                        text="{backend>warehouseNo}" />
                </ComboBox>

                <Label
                    id="workCenterLabel"
                    text="Work Center" />

                <ComboBox
                    id="workCenterSelect"
                    selectedKey="{loginDraft>/workCenterId}"
                    items="{backend>/WorkCenters}">
                    <core:Item
                        key="{backend>workCenterId}"
                        text="{backend>workCenterId}" />
                </ComboBox>

                <Label
                    id="resourceLabel"
                    text="Resource" />

                <ComboBox
                    id="resourceSelect"
                    selectedKey="{loginDraft>/resourceId}"
                    items="{backend>/Resources}">
                    <core:Item
                        key="{backend>resourceId}"
                        text="{backend>resourceId}" />
                </ComboBox>

            </VBox>

        </content>

        <footer>

            <Toolbar
                id="footerToolbar">

                <ToolbarSpacer id="footerToolbarSpacer" />

                <Button
                    id="loginButton"
                    text="Login" />

            </Toolbar>

        </footer>

    </Popover>

</core:FragmentDefinition>