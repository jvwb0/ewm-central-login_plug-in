{
  "compilerOptions": {
    "target": "es2022",
    "module": "es2022",
    // "moduleResolution": "node", deprecated in favor of "moduleResolution": "bundler"
    "moduleResolution": "bundler",
    "ignoreDeprecations": "5.0",
    "skipLibCheck": true,
    "allowJs": true,
    "strict": true,
    "strictPropertyInitialization": false,
    "rootDir": "./webapp",
    "outDir": "./dist",
    "paths": {
      "brown/centralewmlogin/*": [
        "./webapp/*"
      ],
      "unit/*": [
        "./webapp/test/unit/*"
      ],
      "integration/*": [
        "./webapp/test/integration/*"
      ]
    }
  },
  "include": [
    "./webapp/**/*"
  ]
}